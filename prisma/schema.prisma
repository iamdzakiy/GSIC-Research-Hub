# ============================================================
# FIREBASE CONFIGURATION - CENTRALIZED DATABASE
# ============================================================
# Semua database terpusat di Firebase (Firestore, Auth, Storage)
# Tidak ada database eksternal lain (PostgreSQL, MySQL, dll)
# ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  // PostgreSQL tidak digunakan - semua data di Firebase Firestore
  // File ini dipertahankan untuk kompatibilitas, tapi tidak aktif
  provider = "postgresql"
  url      = env("DATABASE_URL") // Tidak perlu diset jika hanya menggunakan Firebase
}
